# Stripe — get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend — get from resend.com (free tier works)
RESEND_API_KEY=re_...
RESEND_FROM_DOMAIN=yourdomain.com

# Store owner email (receives order notifications)
OWNER_EMAIL=uncle@example.com

# This site's public URL
NEXT_PUBLIC_SITE_URL=https://stickers.yourdomain.com

# Links to your other two sites (shown in footer)
NEXT_PUBLIC_FINEART_URL=https://fineart.yourdomain.com
NEXT_PUBLIC_PHOTOGRAPHY_URL=https://photography.yourdomain.com
